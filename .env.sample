# Common PostgreSQL settings
PGHOST=app_server_host
PGPORT=5432
PGDATABASE=adsb_test
PGUSER=lab_rw
PGPASSWORD=CHANGE_ME

# AMeDAS ingest settings (used on app_server)
# Comma-separated list of AMeDAS station IDs
AMEDAS_IDS=44132,45401,46106

# Optional: override JMA AMeDAS base URL (normally you do not need to change this)
#JMA_AMEDAS_BASE_URL=https://www.jma.go.jp/bosai/amedas/data/point

# ADS-B ingest settings (if you also run adsb_ingest on this host)
# Site code must match adsb_aircraft.site_code
#ADS_SITE_CODE=site1

# Dump1090-fa / readsb JSON endpoint
#ADS_JSON_URL=http://localhost/skyaware/data/aircraft.json
